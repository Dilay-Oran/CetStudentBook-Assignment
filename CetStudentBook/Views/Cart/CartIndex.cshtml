@model IEnumerable<CetStudentBook.Models.CartItem>

<h2>My Cart</h2>

<table class="table">
    <thead>
        <tr>
            <th>Book Name</th>
            <th>Quantity</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Book?.Name</td>
                <td>@item.Quantity</td>
            </tr>
        }
    </tbody>
</table>

<div class="text-end">
    <a asp-controller="Cart" asp-action="Purchase" class="btn btn-success">Buy</a>
</div>