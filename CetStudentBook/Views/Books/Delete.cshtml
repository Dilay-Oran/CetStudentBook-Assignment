@model CetStudentBook.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<div class="alert alert-danger">
    Are you sure you want to delete this book?
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Book Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Author</dt>
            <dd class="col-sm-8">@Model.Author</dd>

            <dt class="col-sm-4">Publish Date</dt>
            <dd class="col-sm-8">@Model.PublishDate.ToShortDateString()</dd>

            <dt class="col-sm-4">Page Count</dt>
            <dd class="col-sm-8">@Model.PageCount</dd>

            <dt class="col-sm-4">Second Hand?</dt>
            <dd class="col-sm-8">@(Model.IsSecondHand ? "Yes" : "No")</dd>
        </dl>
    </div>
</div>

<br />
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>